/* --- Fenêtre de migration --- */
"Migrate / rotate vault" = "Migrer / renouveler le coffre";
"Re-encrypts everything into a brand-new vault file with fresh keys (the same passphrase). Your files are copied and verified before anything is replaced; nothing is written to disk in the clear. The original is kept until you delete it." = "Re-chiffre tout dans un tout nouveau fichier coffre avec de nouvelles clés (la même phrase secrète). Vos fichiers sont copiés et vérifiés avant tout remplacement ; rien n’est écrit en clair sur le disque. L’original est conservé jusqu’à ce que vous le supprimiez.";
"New size" = "Nouvelle taille";
"Keep current capacity" = "Conserver la capacité actuelle";
"Shrink to fit contents" = "Réduire à la taille du contenu";
"Destination:" = "Destination :";
"Needs about %@; %@ free here." = "Nécessite environ %@ ; %@ libres ici.";
"This vault requires a YubiKey" = "Ce coffre nécessite une YubiKey";
"Migrate" = "Migrer";
"Use Folder" = "Utiliser ce dossier";
"Not enough space on %@: the new vault needs about %@ but only %@ is free. Choose “Shrink to fit” or a different drive." = "Espace insuffisant sur %@ : le nouveau coffre nécessite environ %@ mais seulement %@ sont libres. Choisissez « Réduire à la taille du contenu » ou un autre disque.";
"A file named “%@” already exists in that folder. Pick another destination." = "Un fichier nommé « %@ » existe déjà dans ce dossier. Choisissez une autre destination.";
"Migration failed: %@. Your original vault is unchanged." = "Échec de la migration : %@. Votre coffre original est inchangé.";
"Migrated. The previous vault is kept as “%@” — delete it once you’ve confirmed this one works." = "Migré. L’ancien coffre est conservé sous « %@ » — supprimez-le une fois que vous avez confirmé que celui-ci fonctionne.";
"Migrated to %@. Your original vault is unchanged — delete it when ready." = "Migré vers %@. Votre coffre original est inchangé — supprimez-le quand vous êtes prêt.";
"Migration verified but the file swap failed: %@. Your original vault is unchanged." = "Migration vérifiée mais l’échange des fichiers a échoué : %@. Votre coffre original est inchangé.";

/* --- Avis de renommage à la création --- */
"“%@” already existed — created “%@” instead. A vault is never overwritten." = "« %@ » existait déjà — « %@ » a été créé à la place. Un coffre n’est jamais écrasé.";

