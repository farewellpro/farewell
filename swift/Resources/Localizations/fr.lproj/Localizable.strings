"5 minutes" = "5 minutes";
"15 minutes" = "15 minutes";
"30 minutes" = "30 minutes";
"Never" = "Jamais";
"The vault always locks on system sleep and screen lock. Inactivity is measured system-wide." = "Le coffre se verrouille toujours à la mise en veille et au verrouillage de l’écran. L’inactivité est mesurée à l’échelle du système.";
"About Farewell" = "À propos de Farewell";
"sleep" = "veille";
"screen lock" = "verrouillage de l’écran";
"inactivity" = "inactivité";
"Vault locked automatically (%@). Unlock to continue." = "Coffre verrouillé automatiquement (%@). Déverrouillez pour continuer.";

