"New size" = "Nuevo tamaño";
"Keep current capacity" = "Mantener la capacidad actual";
"Shrink to fit contents" = "Reducir al tamaño del contenido";
"Destination:" = "Destino:";
"Needs about %@; %@ free here." = "Necesita unos %@; %@ libres aquí.";
