/* --- Import bar --- */
"New note" = "Nueva nota";
"Create a new empty note and open it in the editor. It lives only inside the encrypted vault." = "Crea una nota vacía y ábrela en el editor. Solo existe dentro de la caja fuerte cifrada.";
"1 pass" = "1 pasada";
"3 passes" = "3 pasadas";
"7 passes" = "7 pasadas";
