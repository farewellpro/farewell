"No vault at this path. Check the location, or use Choose…." = "هیچ گاوصندوقی در این مسیر نیست. مکان را بررسی کنید، یا از «انتخاب…» استفاده کنید.";

/* --- Manage-license sheet --- */
"License" = "مجوز";
"Paste the license key you received by email, then Activate. Everything is verified locally — Farewell never contacts a server." = "کلید مجوزی را که با ایمیل دریافت کرده‌اید بچسبانید، سپس «فعال‌سازی» را بزنید. همه چیز به‌صورت محلی بررسی می‌شود — Farewell هرگز با هیچ سروری تماس نمی‌گیرد.";
"Open file…" = "باز کردن فایل…";
"Close" = "بستن";
"Activate" = "فعال‌سازی";
"Licensed to %@ — %@" = "دارای مجوز برای %@ — %@";
"Not activated on this Mac" = "روی این Mac فعال نشده";

