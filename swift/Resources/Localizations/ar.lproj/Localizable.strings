/* --- Open / Create / Unlock screen --- */
"Open vault" = "فتح خزنة";
"Create vault" = "إنشاء خزنة";
"Licensed to %@" = "مُرخَّص لـ %@";
"Not activated" = "غير مُفعَّل";
"Manage license…" = "إدارة الترخيص…";

/* Open form */
"Vault path" = "مسار الخزنة";
"Choose…" = "اختيار…";
"Passphrase" = "عبارة المرور";
"Using a hardware key with a PIN?" = "هل تستخدم مفتاحاً مادياً مع رمز PIN؟";
"YubiKey PIN" = "رمز PIN لمفتاح YubiKey";
"Leave the PIN blank if your key has none. You'll be asked to touch the key if this vault requires it." = "اترك رمز PIN فارغاً إذا كان مفتاحك بلا رمز. سيُطلب منك لمس المفتاح إذا كانت هذه الخزنة تتطلب ذلك.";
"Unlock" = "فتح القفل";
