"vault not open" = "الخزنة غير مفتوحة";
"empty name" = "اسم فارغ";
"cannot stat %@" = "تعذّر فحص %@";
"cannot read %@" = "تعذّرت قراءة %@";
"“%@” is %@ but only %@ is free in this level." = "حجم « %@ » هو %@ لكن المتاح %@ فقط في هذا المستوى.";
"Not enough space: the edit needs %@ but only %@ is available." = "لا توجد مساحة كافية: يحتاج التعديل إلى %@ لكن المتاح %@ فقط.";

