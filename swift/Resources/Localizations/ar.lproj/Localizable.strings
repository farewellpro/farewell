"counter %llu" = "العدّاد %llu";
"%lld hardware keys" = "%lld مفاتيح مادية";
"created by %@" = "أنشأها %@";
"An interrupted migration left “%@”. Your vault is intact." = "ترك ترحيلٌ مُتوقَّف « %@ ». خزنتك سليمة.";

/* --- File list / folders --- */
"This vault contains no files." = "لا تحتوي هذه الخزنة على أي ملفات.";
"Drag files here, or use Import below." = "اسحب الملفات إلى هنا، أو استخدم استيراد بالأسفل.";
"Search files…" = "بحث في الملفات…";
"No file matches “%@”." = "لا يوجد ملف يطابق « %@ ».";
"Drop to import into the vault" = "أفلت للاستيراد إلى الخزنة";
"New folder" = "مجلد جديد";
"New folder in “%@”" = "مجلد جديد في « %@ »";
"Import…" = "استيراد…";
"Delete" = "حذف";
"Rename" = "إعادة تسمية";

/* --- File / folder dialogs --- */
"Delete this file?" = "حذف هذا الملف؟";
"“%@” will be permanently removed and its encrypted chunks securely shredded. This cannot be undone — there is no recovery, by design." = "ستُحذف « %@ » نهائياً وتُمزَّق أجزاؤها المُشفَّرة بأمان. لا يمكن التراجع عن هذا — لا يوجد استرداد، عن قصد.";
"Delete this folder?" = "حذف هذا المجلد؟";
"“%@” and ALL its contents will be permanently removed and securely shredded. This cannot be undone." = "ستُحذف « %@ » وكل محتوياتها نهائياً وتُمزَّق بأمان. لا يمكن التراجع عن هذا.";
"Folder name" = "اسم المجلد";
"Create" = "إنشاء";
"Rename file" = "إعادة تسمية الملف";
"Renaming “%@”. The encrypted content is unchanged; only the name in the manifest is updated." = "إعادة تسمية « %@ ». المحتوى المُشفَّر لا يتغير؛ يُحدَّث الاسم فقط في الفهرس.";
"New name" = "الاسم الجديد";

/* --- Import bar --- */
"New note" = "ملاحظة جديدة";
"Create a new empty note and open it in the editor. It lives only inside the encrypted vault." = "أنشئ ملاحظة فارغة جديدة وافتحها في المحرر. توجد فقط داخل الخزنة المُشفَّرة.";
"1 pass" = "تمريرة واحدة";
"3 passes" = "3 تمريرات";
"7 passes" = "7 تمريرات";
"Overwrite passes. 1 is enough on any modern drive; 3/7 exist only for standards that mandate them and add nothing on an SSD." = "تمريرات الكتابة فوق البيانات. تكفي تمريرة واحدة على أي قرص حديث؛ 3/7 موجودة فقط للمعايير التي تفرضها ولا تضيف شيئاً على قرص SSD.";
"Shred originals" = "تمزيق الأصول";
"After importing, securely overwrite and delete the source file. On a hard disk this physically erases it; on an SSD wear-leveling means it's best-effort only (no guarantee) — the real protection is the encrypted vault." = "بعد الاستيراد، اكتب فوق ملف المصدر واحذفه بأمان. على القرص الصلب يمحوه فيزيائياً؛ على قرص SSD، تعني موازنة التآكل أنه أفضل جهد فقط (دون ضمان) — الحماية الحقيقية هي الخزنة المُشفَّرة.";
"Drag files here, or click Import. Files are encrypted into the vault; nothing is written elsewhere." = "اسحب الملفات إلى هنا، أو اضغط استيراد. تُشفَّر الملفات داخل الخزنة؛ لا يُكتب أي شيء في أي مكان آخر.";
"Imported %lld; last error: %@" = "تم استيراد %lld؛ آخر خطأ: %@";
"Imported 1 file." = "تم استيراد ملف واحد.";
"Imported %lld files." = "تم استيراد %lld ملفات.";
"Original securely erased (overwritten %lld× in place on a hard disk)." = "تم محو الأصل بأمان (كُتب فوقه %lld× في مكانه على قرص صلب).";
"Original overwritten + deleted — but this is an SSD: wear-leveling means the cells may persist. The real protection is the encrypted vault, not the wipe." = "كُتب فوق الأصل + حُذف — لكن هذا قرص SSD: تعني موازنة التآكل أن الخلايا قد تبقى. الحماية الحقيقية هي الخزنة المُشفَّرة، وليس المحو.";
"Original overwritten + deleted (storage type unknown; treated as flash — no physical-erase guarantee)." = "كُتب فوق الأصل + حُذف (نوع التخزين غير معروف؛ يُعامَل كذاكرة فلاش — دون ضمان محو فيزيائي).";

/* --- File viewer --- */
"Save" = "حفظ";
"Save the changes back into the encrypted vault. Nothing is written to disk." = "احفظ التغييرات في الخزنة المُشفَّرة. لا يُكتب أي شيء على القرص.";
"Edit" = "تحرير";
"Edit this text file in the app and save it back into the vault. Nothing is written to disk." = "حرّر هذا الملف النصي في التطبيق وأعد حفظه في الخزنة. لا يُكتب أي شيء على القرص.";
"Export…" = "تصدير…";
"Write a decrypted copy of this file to disk, outside the vault. Shows a warning first." = "اكتب نسخة مُفكّكة التشفير من هذا الملف على القرص، خارج الخزنة. يعرض تحذيراً أولاً.";
"The vault isn’t open." = "الخزنة غير مفتوحة.";

/* --- Export warning --- */
"Export a decrypted copy?" = "تصدير نسخة مُفكّكة التشفير؟";
"You are about to write the decrypted contents of “%@” to a regular file on disk. Once written, that file leaves Farewell's protection:" = "أنت على وشك كتابة المحتوى المُفكّك التشفير لـ « %@ » في ملف عادي على القرص. بمجرد كتابته، يخرج ذلك الملف من حماية Farewell:";
"Spotlight will index its contents" = "سيفهرس Spotlight محتواه";
"QuickLook will cache a thumbnail" = "سيخزّن QuickLook صورة مصغّرة مؤقتاً";
"Time Machine will back it up (if enabled)" = "ستنسخه Time Machine احتياطياً (إن كان مُفعَّلاً)";
"Apps that open it keep it in Recent Items" = "التطبيقات التي تفتحه تحتفظ به في العناصر الأخيرة";
"Farewell can no longer track or recall it" = "لم يعد بإمكان Farewell تتبعه أو استرجاعه";
"Use the in-app viewer instead unless you genuinely need an external copy. For device-to-device transfer, Farewell-to-Farewell P2P (coming later) never writes cleartext to disk." = "استخدم العارض داخل التطبيق بدلاً من ذلك ما لم تكن بحاجة فعلاً إلى نسخة خارجية. للنقل بين الأجهزة، فإن خاصية Farewell-إلى-Farewell الند للند (قادمة لاحقاً) لا تكتب أبداً نصاً غير مُشفَّر على القرص.";
"Export anyway" = "تصدير على أي حال";
"This file will be written UNENCRYPTED outside the vault." = "سيُكتب هذا الملف غير مُشفَّر خارج الخزنة.";

/* --- Migrate sheet --- */
"Migrate / rotate vault" = "ترحيل / تدوير الخزنة";
"Re-encrypts everything into a brand-new vault file with fresh keys (the same passphrase). Your files are copied and verified before anything is replaced; nothing is written to disk in the clear. The original is kept until you delete it." = "يعيد تشفير كل شيء في ملف خزنة جديد تماماً بمفاتيح جديدة (نفس عبارة المرور). تُنسخ ملفاتك ويُتحقق منها قبل استبدال أي شيء؛ لا يُكتب أي شيء على القرص بشكل واضح. يُحتفظ بالأصل حتى تحذفه.";
"New size" = "الحجم الجديد";
"Keep current capacity" = "الإبقاء على السعة الحالية";
"Shrink to fit contents" = "التقليص ليناسب المحتوى";
"Destination:" = "الوجهة:";
"Needs about %@; %@ free here." = "يحتاج إلى نحو %@؛ %@ متاح هنا.";
"This vault requires a YubiKey" = "تتطلب هذه الخزنة مفتاح YubiKey";
"Migrate" = "ترحيل";
"Use Folder" = "استخدام المجلد";
"Not enough space on %@: the new vault needs about %@ but only %@ is free. Choose “Shrink to fit” or a different drive." = "لا توجد مساحة كافية على %@: تحتاج الخزنة الجديدة إلى نحو %@ لكن المتاح %@ فقط. اختر « التقليص ليناسب المحتوى » أو قرصاً آخر.";
"A file named “%@” already exists in that folder. Pick another destination." = "يوجد بالفعل ملف باسم « %@ » في ذلك المجلد. اختر وجهة أخرى.";
"Migration failed: %@. Your original vault is unchanged." = "فشل الترحيل: %@. خزنتك الأصلية لم تتغير.";
"Migrated. The previous vault is kept as “%@” — delete it once you’ve confirmed this one works." = "تم الترحيل. يُحتفظ بالخزنة السابقة باسم « %@ » — احذفها بمجرد أن تتأكد من أن هذه تعمل.";
"Migrated to %@. Your original vault is unchanged — delete it when ready." = "تم الترحيل إلى %@. خزنتك الأصلية لم تتغير — احذفها عندما تكون جاهزاً.";
"Migration verified but the file swap failed: %@. Your original vault is unchanged." = "تم التحقق من الترحيل لكن فشل تبديل الملفات: %@. خزنتك الأصلية لم تتغير.";

/* --- Create-vault rename notice --- */
"“%@” already existed — created “%@” instead. A vault is never overwritten." = "« %@ » كانت موجودة بالفعل — تم إنشاء « %@ » بدلاً منها. لا يُستبدَل أي خزنة أبداً.";

