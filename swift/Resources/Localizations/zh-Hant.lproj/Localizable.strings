   =================================================================== */

/* --- Open / Create / Unlock screen --- */
"Open vault" = "開啟保險庫";
"Create vault" = "建立保險庫";
"Licensed to %@" = "已授權給 %@";
"Not activated" = "未啟用";
"Manage license…" = "管理許可證…";

/* Open form */
"Vault path" = "保險庫路徑";
"Choose…" = "選擇…";
"Passphrase" = "密碼短語";
"Using a hardware key with a PIN?" = "使用帶 PIN 碼的硬體金鑰？";
"YubiKey PIN" = "YubiKey PIN 碼";
"Leave the PIN blank if your key has none. You'll be asked to touch the key if this vault requires it." = "如果你的金鑰沒有 PIN 碼，請留空。如果此保險庫需要，系統會要求你輕觸金鑰。";
"Unlock" = "解鎖";
"No vault at this path. Check the location, or use Choose…." = "此路徑下沒有保險庫。請檢查位置，或使用「選擇…」。";

