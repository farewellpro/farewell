"Invalid argument" = "参数无效";
"Not found" = "未找到";
"Couldn't read the vault file (missing or unreadable)." = "无法读取保险库文件（缺失或不可读）。";
"This vault is already open in another window or process." = "此保险库已在另一个窗口或进程中打开。";
