"Remove that key, then insert the next one…" = "请拔下该密钥，然后插入下一个…";
" — touch %lld of %lld" = "——轻触第 %lld 次，共 %lld 次";
"Key %lld of %lld: touch it now" = "第 %lld 个密钥，共 %lld 个：现在轻触它";
"Touch your YubiKey now" = "现在轻触你的 YubiKey";
